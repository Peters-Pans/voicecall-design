# ========================================
# 音色克隆语音通话系统 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填入真实值

# --- 小米 TTS API ---
XIAOMI_API_KEY=tp-your-api-key-here
XIAOMI_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions
XIAOMI_TTS_MODEL=mimo-v2.5-tts-voiceclone

# --- LLM API (OpenAI 兼容格式) ---
LLM_API_KEY=sk-your-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- 服务器 ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
